{
  "name": "claude-permissions-manager",
  "version": "1.2.8",
  "description": "Discover, analyze, and manage Claude Code permissions across all your projects",
  "license": "MIT",
  "author": "stofi",
  "keywords": [
    "claude",
    "claude-code",
    "permissions",
    "mcp",
    "cli",
    "security"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stofi/claude-permissions-manager.git"
  },
  "homepage": "https://github.com/stofi/claude-permissions-manager#readme",
  "bugs": {
    "url": "https://github.com/stofi/claude-permissions-manager/issues"
  },
  "type": "module",
  "bin": {
    "cpm": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc && chmod +x dist/cli.js",
    "prepublishOnly": "npm run clean && npm run build && npm test && npm run typecheck",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "ink": "^5.0.1",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^4.1.2"
  }
}
