{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "secret"
      }
    },
    "filesystem": {
      "type": "http",
      "url": "https://mcp.example.com/fs",
      "headers": {
        "Authorization": "Bearer token"
      }
    }
  }
}
